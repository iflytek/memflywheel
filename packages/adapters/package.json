{
  "name": "@memflywheel/adapters",
  "version": "0.1.0",
  "description": "Host lifecycle adapters for wiring MemFlywheel into agent runtimes.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "NOTICE",
    "THIRD_PARTY_LICENSES",
    "pi-extension/**/*.mjs",
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "!dist/**/*.test.js",
    "!dist/**/*.test.d.ts",
    "!dist/test-helpers.js",
    "!dist/test-helpers.d.ts"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iflytek/memflywheel.git",
    "directory": "packages/adapters"
  },
  "bugs": {
    "url": "https://github.com/iflytek/memflywheel/issues"
  },
  "homepage": "https://github.com/iflytek/memflywheel#readme",
  "keywords": [
    "agent-memory",
    "adapters",
    "llm",
    "memory",
    "pi-package",
    "typescript"
  ],
  "pi": {
    "extensions": [
      "./pi-extension/index.mjs"
    ]
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22.13"
  },
  "scripts": {
    "build": "rm -rf dist tsconfig.tsbuildinfo && tsc -b",
    "test": "tsc -b && node --test \"dist/**/*.test.js\"",
    "clean": "rm -rf dist tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@memflywheel/model": "workspace:*",
    "@memflywheel/sdk": "workspace:*",
    "@memflywheel/skills": "workspace:*"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*"
  },
  "peerDependenciesMeta": {
    "@earendil-works/pi-ai": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.20.0",
    "typescript": "^5.5.4"
  }
}
