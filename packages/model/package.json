{
  "name": "@memflywheel/model",
  "version": "0.1.0",
  "private": true,
  "description": "Provider-neutral tool-calling model protocol for MemFlywheel.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "NOTICE",
    "THIRD_PARTY_LICENSES",
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "!dist/**/*.test.js",
    "!dist/**/*.test.d.ts"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iflytek/memflywheel.git",
    "directory": "packages/model"
  },
  "bugs": {
    "url": "https://github.com/iflytek/memflywheel/issues"
  },
  "homepage": "https://github.com/iflytek/memflywheel#readme",
  "keywords": [
    "agent-memory",
    "llm",
    "memory",
    "tool-calling",
    "typescript"
  ],
  "engines": {
    "node": ">=22.13"
  },
  "scripts": {
    "build": "rm -rf dist tsconfig.tsbuildinfo && tsc -b",
    "test": "tsc -b && node --test \"dist/**/*.test.js\"",
    "clean": "rm -rf dist tsconfig.tsbuildinfo"
  },
  "devDependencies": {
    "@types/node": "^22.20.1",
    "typescript": "^5.5.4"
  }
}
